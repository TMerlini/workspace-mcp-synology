# ============================================================================
# Google Workspace MCP - Coolify Deployment Configuration
# ============================================================================
# Copy this to .env or configure these as environment variables in Coolify
#
# IMPORTANT: Get your Google OAuth credentials first!
# 1. Go to: https://console.cloud.google.com/
# 2. Create a new project or select existing
# 3. Enable required APIs (Gmail, Drive, Calendar, Docs, Sheets, etc.)
# 4. Create OAuth 2.0 credentials (Desktop Application type)
# 5. Copy the Client ID and Client Secret below
# ============================================================================

# ---------------------------------------------------------------------------
# REQUIRED: Google OAuth Credentials
# ---------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id-here
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret-here

# ---------------------------------------------------------------------------
# REQUIRED: OAuth 2.1 Multi-User Support (for remote hosting)
# ---------------------------------------------------------------------------
MCP_ENABLE_OAUTH21=true

# ---------------------------------------------------------------------------
# REQUIRED: Stateless Mode (for container deployments)
# ---------------------------------------------------------------------------
WORKSPACE_MCP_STATELESS_MODE=true

# ---------------------------------------------------------------------------
# REQUIRED: External URL Configuration
# ---------------------------------------------------------------------------
# Set this to your Coolify-provided domain (e.g., https://your-app.coolify.domain)
# Coolify will provide this - update after deployment
WORKSPACE_EXTERNAL_URL=https://your-domain-here.com

# ---------------------------------------------------------------------------
# Server Configuration
# ---------------------------------------------------------------------------
WORKSPACE_MCP_HOST=0.0.0.0
WORKSPACE_MCP_PORT=8000

# ---------------------------------------------------------------------------
# Tool Selection (Optional - choose one approach)
# ---------------------------------------------------------------------------
# Option 1: Use tool tiers (recommended)
# TOOL_TIER=core       # Essential tools only
# TOOL_TIER=extended   # Core + management features
# TOOL_TIER=complete   # All available tools

# Option 2: Select specific services
# TOOLS=gmail drive calendar docs sheets

# ---------------------------------------------------------------------------
# OAuth Proxy Storage Backend (Optional)
# ---------------------------------------------------------------------------
# For single-server: use disk (default)
WORKSPACE_MCP_OAUTH_PROXY_STORAGE_BACKEND=disk

# For distributed/multi-container: use valkey/redis
# WORKSPACE_MCP_OAUTH_PROXY_STORAGE_BACKEND=valkey
# WORKSPACE_MCP_OAUTH_PROXY_VALKEY_HOST=redis.example.com
# WORKSPACE_MCP_OAUTH_PROXY_VALKEY_PORT=6379
# WORKSPACE_MCP_OAUTH_PROXY_VALKEY_PASSWORD=your-redis-password

# ---------------------------------------------------------------------------
# Optional: Custom Search Engine (if using search tools)
# ---------------------------------------------------------------------------
# GOOGLE_PSE_API_KEY=your-api-key
# GOOGLE_PSE_ENGINE_ID=your-engine-id

# ---------------------------------------------------------------------------
# Optional: Read-Only Mode
# ---------------------------------------------------------------------------
# Uncomment to enable read-only access (no write operations)
# This will be passed as --read-only flag to main.py
# READ_ONLY=true

# ---------------------------------------------------------------------------
# Optional: Granular Permissions
# ---------------------------------------------------------------------------
# Per-service permission levels (alternative to read-only mode)
# Format: service:level (e.g., gmail:organize drive:readonly)
# PERMISSIONS=gmail:organize drive:readonly

# ---------------------------------------------------------------------------
# Security Settings
# ---------------------------------------------------------------------------
# Allowed directories for local file access (colon-separated on Linux, semicolon on Windows)
# ALLOWED_FILE_DIRS=/app/uploads:/app/attachments

# Custom encryption key for OAuth proxy storage (optional but recommended)
# FASTMCP_SERVER_AUTH_GOOGLE_JWT_SIGNING_KEY=your-secure-random-key-here

# ---------------------------------------------------------------------------
# Development Settings (DO NOT USE IN PRODUCTION)
# ---------------------------------------------------------------------------
# OAUTHLIB_INSECURE_TRANSPORT=1  # Only for local http:// testing
